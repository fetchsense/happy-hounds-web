# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# Admin password for /admin/* routes (HTTP Basic Auth).
# Choose a strong, random password (e.g. `openssl rand -hex 20`).
# If not set: admin routes are open in development, blocked (503) in production.
ADMIN_SECRET=change-me

# Gmail App Password for sending booking confirmation emails.
# The "From" address is always happyhoundstrainingacademy@gmail.com.
# To generate one: Google Account → Security → 2-Step Verification → App Passwords
# If not set: emails are skipped (bookings still work, confirmation is on-screen only).
EMAIL_APP_PASSWORD=

# Stripe payment keys — use TEST (sandbox) keys for development.
# Find these at https://dashboard.stripe.com/test/apikeys
# sk_test_... keys are secret; never expose them client-side.
# Live keys (sk_live_...) must NOT be set until CEO has approved go-live.
STRIPE_SECRET_KEY=sk_test_replace_me
